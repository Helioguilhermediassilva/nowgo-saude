# NowGo Saude - shared dev env vars (copy to .env, do NOT commit secrets)
DATABASE_URL=postgresql+psycopg://nowgo:nowgo_dev@localhost:5432/nowgo_saude
REDIS_URL=redis://localhost:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nowgo-saude-backend
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
NEXT_PUBLIC_OTEL_SERVICE_NAME=nowgo-saude-frontend

# JWT stub (replace with OIDC in prod)
JWT_SECRET=dev_only_change_me
JWT_ALGORITHM=HS256

# Egress allowlist (comma-separated hostnames). egress_guard rejects everything else.
EGRESS_ALLOWLIST=api.x.ai,api.openai.com

# Grok adapter (LLM provider)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai
