# NowGo Saúde — frontend environment variables
# Copy to .env.local for local dev or set in Vercel project settings.

# OpenTelemetry (already wired via instrumentation.ts)
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=
NEXT_PUBLIC_OTEL_SERVICE_NAME=nowgo-saude-frontend

# FastAPI backend bridge (server-only, never exposed to the browser).
# Leave unset to keep using the local mock layer.
BACKEND_API_URL=
BACKEND_API_TOKEN=
